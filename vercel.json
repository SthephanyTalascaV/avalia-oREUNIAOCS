{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/ingest.js":  { "maxDuration": 30 },
    "api/analyze.js": { "maxDuration": 300 },
    "api/*.js":       { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/me",                    "destination": "/api/auth?_route=me" },
    { "source": "/api/coordinators",          "destination": "/api/team?_route=coordinators" },
    { "source": "/api/summarize-melhorias",   "destination": "/api/export?_route=summarize" }
  ]
}
